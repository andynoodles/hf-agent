# --- OpenAI (or any OpenAI-compatible endpoint, e.g. Ollama, vLLM, OpenRouter) ---
OPENAI_API_KEY=
# Default https://api.openai.com/v1 ; change for compatible providers
OPENAI_BASE_URL=https://localhost:8000v1
# Single model, or comma-separated list shown in /models
OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODELS=gpt-4o-mini,gpt-4o,gpt-4.1-mini

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_MODELS=gemini-2.0-flash,gemini-1.5-pro
